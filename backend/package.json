{
  "name": "grhapoch-delivery-backend",
  "version": "1.0.0",
  "description": "Backend API for GrhaPoch Delivery Platform",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node --disable-warning=MONGOOSE server.js",
    "dev": "node --watch --disable-warning=MONGOOSE server.js",
    "kill-port": "npx kill-port 5000 || (for /f \"tokens=5\" %a in ('netstat -ano ^| findstr LISTENING ^| findstr :5000') do taskkill /F /PID %a)",
    "fresh": "npm run kill-port && npm run dev",
    "test": "echo \"Error: no test specified\" && exit 1",
    "cleanup:fcm-arrays": "node ./scripts/removeLegacyFcmArrays.js"
  },
  "keywords": [
    "food-delivery",
    "express",
    "mongodb",
    "jwt"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.8.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^10.3.0",
    "google-auth-library": "^10.5.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.12",
    "razorpay": "^2.9.6",
    "redis": "^4.6.12",
    "socket.io": "^4.6.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
